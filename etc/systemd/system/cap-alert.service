[Unit]
Description=CAP-Alert weather alert check
After=network.target asterisk.service
Wants=asterisk.service
OnFailure=cap-alert-failure.service

[Service]
Type=oneshot
User=asterisk
Group=asterisk
ExecStart=/usr/bin/cap-alert run
StandardOutput=append:/var/log/cap-alert/cap-alert.log
StandardError=append:/var/log/cap-alert/cap-alert.log
ProtectSystem=strict
ProtectHome=true
PrivateTmp=false
ReadWritePaths=/var/lib/cap-alert /var/log/cap-alert /tmp /run/asterisk
