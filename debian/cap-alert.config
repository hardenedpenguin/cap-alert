#!/bin/sh
set -e

. /usr/share/debconf/confmodule

WRITE_CONFIG="/usr/lib/cap-alert/write-config-from-debconf"

NODE_RE='^[0-9]+$'
COORD_RE='^-?[0-9]+(\.[0-9]+)?$'
RADIUS_RE='^[0-9]+$'
HOURS_RE='^[0-9]+(\.[0-9]+)?$'
MINUTE_RE='^([0-9]|[1-5][0-9])$'

validate_replay_hours() {
	hours="$1"
	echo "$hours" | grep -Eq "$HOURS_RE" || return 1
	awk "BEGIN { exit !($hours > 0 && $hours <= 168) }"
}

validate_minute() {
	minute="$1"
	echo "$minute" | grep -Eq "$MINUTE_RE"
}

validate_node() {
	node="$1"
	echo "$node" | grep -Eq "$NODE_RE"
}

validate_lat() {
	lat="$1"
	echo "$lat" | grep -Eq "$COORD_RE" || return 1
	awk "BEGIN { exit !($lat >= -90 && $lat <= 90) }"
}

validate_lon() {
	lon="$1"
	echo "$lon" | grep -Eq "$COORD_RE" || return 1
	awk "BEGIN { exit !($lon >= -180 && $lon <= 180) }"
}

validate_radius() {
	radius="$1"
	echo "$radius" | grep -Eq "$RADIUS_RE" && [ "$radius" -gt 0 ]
}

validate_gps_min_satellites() {
	value="$1"
	echo "$value" | grep -Eq "$RADIUS_RE" && [ "$value" -ge 1 ] && [ "$value" -le 30 ]
}

validate_gps_max_age() {
	value="$1"
	echo "$value" | grep -Eq "$RADIUS_RE" && [ "$value" -ge 0 ] && [ "$value" -le 86400 ]
}

ask_required_string() {
	template="$1"
	default="${2:-}"

	while true; do
		db_set "$template" "$default"
		db_input critical "$template" || true
		db_go || return 1
		db_get "$template"
		value="$RET"
		case "$template" in
			cap-alert/node)
				if validate_node "$value"; then
					return 0
				fi
				db_fset cap-alert/node seen false
				db_input high cap-alert/invalid_node || true
				db_go || return 1
				;;
			cap-alert/lat)
				if validate_lat "$value"; then
					return 0
				fi
				db_fset cap-alert/lat seen false
				db_input high cap-alert/invalid_lat || true
				db_go || return 1
				;;
			cap-alert/lon)
				if validate_lon "$value"; then
					return 0
				fi
				db_fset cap-alert/lon seen false
				db_input high cap-alert/invalid_lon || true
				db_go || return 1
				;;
			cap-alert/gps_min_satellites)
				if validate_gps_min_satellites "$value"; then
					return 0
				fi
				db_fset cap-alert/gps_min_satellites seen false
				db_input high cap-alert/invalid_gps_min_satellites || true
				db_go || return 1
				;;
			cap-alert/gps_max_age_seconds)
				if validate_gps_max_age "$value"; then
					return 0
				fi
				db_fset cap-alert/gps_max_age_seconds seen false
				db_input high cap-alert/invalid_gps_max_age || true
				db_go || return 1
				;;
			cap-alert/cyclone_radius)
				if validate_radius "$value"; then
					return 0
				fi
				db_fset cap-alert/cyclone_radius seen false
				db_input high cap-alert/invalid_cyclone_radius || true
				db_go || return 1
				;;
			cap-alert/earthquake_radius)
				if validate_radius "$value"; then
					return 0
				fi
				db_fset cap-alert/earthquake_radius seen false
				db_input high cap-alert/invalid_earthquake_radius || true
				db_go || return 1
				;;
			cap-alert/wildfire_radius)
				if validate_radius "$value"; then
					return 0
				fi
				db_fset cap-alert/wildfire_radius seen false
				db_input high cap-alert/invalid_wildfire_radius || true
				db_go || return 1
				;;
			cap-alert/wildfire_min_acres)
				if validate_radius "$value"; then
					return 0
				fi
				db_fset cap-alert/wildfire_min_acres seen false
				db_input high cap-alert/invalid_wildfire_acres || true
				db_go || return 1
				;;
			cap-alert/replay_hours)
				if validate_replay_hours "$value"; then
					return 0
				fi
				db_fset cap-alert/replay_hours seen false
				db_input high cap-alert/invalid_replay_hours || true
				db_go || return 1
				;;
			cap-alert/pi_hold_minutes|cap-alert/pi_daily_limit|cap-alert/pi_soft_c|cap-alert/pi_hot_c|cap-alert/pi_high_c)
				if validate_radius "$value"; then
					return 0
				fi
				db_fset "$template" seen false
				db_input high cap-alert/invalid_hold_minutes || true
				db_go || return 1
				;;
			cap-alert/playback_window_start|cap-alert/playback_window_end)
				if validate_minute "$value"; then
					return 0
				fi
				db_fset "$template" seen false
				db_input high cap-alert/invalid_playback_minute || true
				db_go || return 1
				;;
		esac
	done
}

run_wizard() {
	db_input medium cap-alert/title || true
	db_go || return 1

	ask_required_string cap-alert/node
	ask_required_string cap-alert/lat
	ask_required_string cap-alert/lon

	db_input high cap-alert/gps_enabled || true
	db_go || return 1
	db_get cap-alert/gps_enabled
	if [ "$RET" = "true" ]; then
		ask_required_string cap-alert/gps_min_satellites 3
		ask_required_string cap-alert/gps_max_age_seconds 120
		db_input high cap-alert/gps_device || true
	fi

	db_input high cap-alert/local_playback || true
	db_input high cap-alert/quiet_hours || true
	db_go || return 1
	db_get cap-alert/quiet_hours
	if [ "$RET" = "true" ]; then
		db_input high cap-alert/quiet_hours_start || true
		db_input high cap-alert/quiet_hours_end || true
		db_input high cap-alert/allow_severe || true
		db_go || return 1
	fi
	ask_required_string cap-alert/replay_hours 4
	db_input high cap-alert/blocked_events || true
	db_input high cap-alert/tail_message_blocked || true
	db_input high cap-alert/repeat_expanded_on_tail || true
	ask_required_string cap-alert/playback_window_start 10
	ask_required_string cap-alert/playback_window_end 50
	db_input high cap-alert/alert_sound_intro || true
	db_input high cap-alert/alert_sound_outro || true
	db_input high cap-alert/tts_key || true
	db_input high cap-alert/tts_voice || true
	db_input high cap-alert/courtesy_tone || true
	db_input high cap-alert/wx_enable_on_severe || true
	db_input high cap-alert/with_county_names || true
	db_go || return 1

	db_input high cap-alert/cyclone_enabled || true
	db_go || return 1
	db_get cap-alert/cyclone_enabled
	if [ "$RET" = "true" ]; then
		db_input high cap-alert/cyclone_feed || true
		ask_required_string cap-alert/cyclone_radius 1000
		db_input high cap-alert/cyclone_hurricanes_only || true
	fi

	db_input high cap-alert/earthquake_enabled || true
	db_go || return 1
	db_get cap-alert/earthquake_enabled
	if [ "$RET" = "true" ]; then
		db_input high cap-alert/earthquake_min_magnitude || true
		ask_required_string cap-alert/earthquake_radius 75
		db_input high cap-alert/earthquake_history_on_enable || true
	fi

	db_input high cap-alert/wildfire_enabled || true
	db_go || return 1
	db_get cap-alert/wildfire_enabled
	if [ "$RET" = "true" ]; then
		ask_required_string cap-alert/wildfire_radius 50
		ask_required_string cap-alert/wildfire_min_acres 250
		db_input high cap-alert/wildfire_exclude_prescribed || true
		db_input high cap-alert/wildfire_history_on_enable || true
	fi

	db_input high cap-alert/pushover_enable || true
	db_go || return 1
	db_get cap-alert/pushover_enable
	if [ "$RET" = "true" ]; then
		db_input high cap-alert/pushover_user_key || true
		db_input high cap-alert/pushover_api_token || true
		db_input high cap-alert/pushover_mode || true
		db_input high cap-alert/pushover_notify_failure || true
		db_input high cap-alert/pushover_notify_all_clear || true
		db_go || return 1
	fi

	db_input high cap-alert/pi_alarms || true
	db_go || return 1
	db_get cap-alert/pi_alarms
	if [ "$RET" = "true" ]; then
		ask_required_string cap-alert/pi_soft_c 65
		ask_required_string cap-alert/pi_hot_c 75
		ask_required_string cap-alert/pi_high_c 80
		ask_required_string cap-alert/pi_hold_minutes 25
		ask_required_string cap-alert/pi_daily_limit 10
	fi
	db_input high cap-alert/cron_interval || true
	db_go || return 1
}

write_config_from_debconf() {
	if [ -x "$WRITE_CONFIG" ]; then
		"$WRITE_CONFIG"
		return
	fi
	echo "cap-alert: $WRITE_CONFIG not found; config will be written on postinst" >&2
}

case "$1" in
	configure|reconfigure)
		if [ "$1" = "reconfigure" ]; then
			run_wizard || exit 10
			write_config_from_debconf || exit 1
		elif [ "${DEBIAN_FRONTEND:-}" = "noninteractive" ]; then
			:
		elif [ ! -f /etc/cap-alert/config.php ]; then
			run_wizard || exit 10
			# Package files are not installed yet; postinst writes config.php.
		fi
		;;
	*)
		;;
esac

exit 0
